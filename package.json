{
  "name": "backend-v3-x-audio",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "cross-env NODE_ENV=development bun run src/main.ts",
    "start:dev": "cross-env NODE_ENV=development bun run --watch src/main.ts",
    "start:debug": "cross-env NODE_ENV=development bun run --debug --watch src/main.ts",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "test": "cross-env NODE_ENV=test bun test --jobs=1",
    "test:watch": "cross-env NODE_ENV=test bun test --watch",
    "test:cov": "cross-env NODE_ENV=test bun test --coverage",
    "test:e2e": "cross-env NODE_ENV=test bun test ./test/*.e2e-spec.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "cross-env NODE_ENV=development bun run scripts/drizzle-seed.ts",
    "db:reset": "cross-env NODE_ENV=development bun run scripts/drizzle-reset.ts",
    "db:generate:test": "bun run --env-file=.env.test.local node_modules/.bin/drizzle-kit generate",
    "db:push:test": "bun run --env-file=.env.test.local node_modules/.bin/drizzle-kit push",
    "db:seed:test": "cross-env NODE_ENV=test bun run scripts/drizzle-seed.ts",
    "db:reset:test": "cross-env NODE_ENV=test bun run scripts/drizzle-reset.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
