    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "test:unit": "cross-env NODE_ENV=test bun test --jobs=1 ./test/unit",
    "test:integration": "cross-env NODE_ENV=test bun test --jobs=1 ./test/integration",
    "test:e2e": "cross-env NODE_ENV=test bun test --jobs=1 ./test/e2e",
    "test:cov": "cross-env NODE_ENV=test bun test ./test/ --coverage"
